# Database Configuration
# Dev: Create free Neon project at https://neon.tech
# Prod: Set these in Vercel Dashboard → Settings → Environment Variables
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require"

REDIS_URL=redis://localhost:6379
JWT_SECRET=<generate: openssl rand -base64 32>
MASTER_KEY=<generate: openssl rand -base64 32>
PORT=4000

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback
FRONTEND_URL=http://localhost:3000

# SMTP / Email (optional — leave empty to disable email notifications)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_API_KEY=
SMTP_FROM=noreply@vaultify.dev
