generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  EDITOR
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String
  avatarUrl    String?
  githubId     String?  @unique
  createdAt    DateTime @default(now())

  ownedWorkspaces     Workspace[]       @relation("WorkspaceOwner")
  memberships         WorkspaceMember[]
  secretsUpdated      Secret[]          @relation("SecretUpdatedBy")
  secretHistoryLogs   SecretHistory[]
  auditLogActions     AuditLog[]
  apiTokens           ApiToken[]
  notifications       Notification[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     User     @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  createdAt DateTime @default(now())

  members       WorkspaceMember[]
  projects      Project[]
  inviteLinks   InviteLink[]
  auditLogs     AuditLog[]
  apiTokens     ApiToken[]
  notifications Notification[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role
  joinedAt    DateTime @default(now())

  workspace      Workspace                    @relation(fields: [workspaceId], references: [id])
  user           User                         @relation(fields: [userId], references: [id])
  environmentOverrides WorkspaceMemberEnvironment[]

  @@unique([workspaceId, userId])
}

model WorkspaceMemberEnvironment {
  id            String   @id @default(cuid())
  memberId      String
  environmentId String
  role          Role

  member      WorkspaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  environment Environment    @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@unique([memberId, environmentId])
}

model Project {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  createdAt   DateTime @default(now())

  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  environments Environment[]
}

model Environment {
  id        String   @id @default(cuid())
  projectId String
  name      String
  createdAt DateTime @default(now())

  project       Project                      @relation(fields: [projectId], references: [id])
  secrets       Secret[]
  memberOverrides WorkspaceMemberEnvironment[]

  @@unique([projectId, name])
}

model Secret {
  id             String   @id @default(cuid())
  environmentId  String
  key            String
  valueEncrypted String
  iv             String
  tag            String
  version        Int      @default(1)
  updatedById    String
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
  workspaceKeyId String?

  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  updatedBy   User            @relation("SecretUpdatedBy", fields: [updatedById], references: [id])
  history     SecretHistory[]

  @@unique([environmentId, key])
}

model SecretHistory {
  id             String   @id @default(cuid())
  secretId       String
  key            String
  valueEncrypted String
  iv             String
  tag            String
  version        Int
  changedById    String
  changedAt      DateTime @default(now())
  workspaceKeyId String?

  secret    Secret @relation(fields: [secretId], references: [id], onDelete: Cascade)
  changedBy User   @relation(fields: [changedById], references: [id])
}

model Notification {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  type        String   // 'secret_created' | 'secret_updated' | 'secret_deleted' | 'secret_revealed'
  title       String
  message     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([workspaceId])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  actorId     String
  action      String
  target      String
  targetId    String?
  details     String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  actor     User      @relation(fields: [actorId], references: [id])
}

model ApiToken {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  name        String
  tokenPrefix String    // e.g. "vlt_abc123..." — first 8 chars for identification
  tokenHash   String    @unique
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([tokenHash])
  @@index([workspaceId])
}

model InviteLink {
  id          String     @id @default(cuid())
  workspaceId String
  tokenHash   String     @unique
  role        Role
  active      Boolean    @default(true)
  email       String?    // Direct email invite — null for link-based
  expiresAt   DateTime?
  maxUses     Int?
  usesCount   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
}

model WorkspaceKey {
  id          String   @id @default(cuid())
  workspaceId String   @unique
  keyEncryptedWithMaster String
  keyIv       String
  keyTag      String
  version     Int      @default(1)
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}
